            const msgDiv = document.getElementById('authMsg');

            if (!name || !email || !password) {
                msgDiv.innerHTML = '<span style="color:#ff453a;">вќЊ Р—Р°РїРѕР»РЅРёС‚Рµ РІСЃРµ РїРѕР»СЏ!</span>';
                return;
            }

            try {
                const userCred = await createUserWithEmailAndPassword(auth, email, password);
                await setDoc(doc(db, 'users', userCred.user.uid), {
                    uid: userCred.user.uid,
                    name: name,
                    email: email,
                    online: true,
                    avatar: null,
                    createdAt: Date.now()
                });
                msgDiv.innerHTML = '<span style="color:#30d158;">вњ… РђРєРєР°СѓРЅС‚ СЃРѕР·РґР°РЅ! РўРµРїРµСЂСЊ РІРѕР№РґРёС‚Рµ.</span>';
                setTimeout(() => msgDiv.innerHTML = '', 2000);
                document.getElementById('regName').value = '';
                document.getElementById('regEmail').value = '';
                document.getElementById('regPassword').value = '';
                // РџРµСЂРµРєР»СЋС‡Р°РµРјСЃСЏ РЅР° С„РѕСЂРјСѓ РІС…РѕРґР°
                document.getElementById('registerForm').style.display = 'none';
                document.getElementById('loginForm').style.display = 'block';
            } catch (e) {
                if (e.code === 'auth/email-already-in-use') {
                    msgDiv.innerHTML = '<span style="color:#ff453a;">вќЊ Р­С‚РѕС‚ email СѓР¶Рµ Р·Р°СЂРµРіРёСЃС‚СЂРёСЂРѕРІР°РЅ!</span>';
                } else {
                    msgDiv.innerHTML = '<span style="color:#ff453a;">вќЊ РћС€РёР±РєР°: ' + e.message + '</span>';
                }
            }
        };

        window.login = async () => {
            const email = document.getElementById('loginEmail').value;
            const password = document.getElementById('loginPassword').value;
            const msgDiv = document.getElementById('authMsg');

            if (!email || !password) {
                msgDiv.innerHTML = '<span style="color:#ff453a;">вќЊ Р’РІРµРґРёС‚Рµ email Рё РїР°СЂРѕР»СЊ!</span>';
                return;
            }

            try {
                await signInWithEmailAndPassword(auth, email, password);
            } catch (e) {
                msgDiv.innerHTML = '<span style="color:#ff453a;">вќЊ РќРµРІРµСЂРЅС‹Р№ email РёР»Рё РїР°СЂРѕР»СЊ</span>';
            }
        };

        async function logout() {
            if (currentUser) {
                await updateDoc(doc(db, 'users', currentUser.uid), { online: false });
            }
            if (settingsModal) {
                settingsModal.classList.add('hidden');
            }
            await signOut(auth);
        }

        async function searchUsers(searchText) {
            if (!searchText.trim() || searchText.length < 2) {
                searchResults.classList.add('hidden');
                return;
            }

            const snapshot = await getDocs(collection(db, 'users'));
            const results = [];
            snapshot.forEach(docSnap => {
                const user = docSnap.data();
                if (user.uid !== currentUser?.uid &&
                    user.name.toLowerCase().includes(searchText.toLowerCase())) {
                    results.push(user);
                }
            });

            if (results.length > 0) {
                searchResults.classList.remove('hidden');
                searchResults.innerHTML = results.map(user => `
                            <div class="search-result-item">
                                <span><strong>${user.name}</strong> (${user.email})</span>
                                <button class="add-friend-btn" onclick="window.startChatWith('${user.uid}')">рџ’¬ РќР°РїРёСЃР°С‚СЊ</button>
                            </div>
                        `).join('');
            } else {
                searchResults.classList.remove('hidden');
                searchResults.innerHTML = '<div style="padding: 10px; color: #98989e;">рџ‘¤ РџРѕР»СЊР·РѕРІР°С‚РµР»СЊ РЅРµ РЅР°Р№РґРµРЅ</div>';
            }
        }

        window.startChatWith = async (friendUid) => {
            const friendDoc = await getDoc(doc(db, 'users', friendUid));
            if (friendDoc.exists()) {
                const friend = friendDoc.data();
                currentChatUser = { uid: friendUid, ...friend };
                updateChatHeader();
                loadMessages();
                if (!chats.find(c => c.uid === friendUid)) {
                    chats.unshift({ uid: friendUid, name: friend.name, avatar: friend.avatar });
                    renderChatsList();
                }
            }
            searchResults.classList.add('hidden');
            searchInput.value = '';
        };

        async function loadChats() {
            if (!currentUser) return;

            const q = query(collection(db, 'messages'), orderBy('timestamp', 'desc'));
            onSnapshot(q, async (snapshot) => {
                const chatUsers = new Map();

                for (const docSnap of snapshot.docs) {
                    const msg = docSnap.data();
                    if (msg.from === currentUser.uid || msg.to === currentUser.uid) {
                        const friendId = msg.from === currentUser.uid ? msg.to : msg.from;
                        if (!chatUsers.has(friendId)) {
                            const userDoc = await getDoc(doc(db, 'users', friendId));
                            if (userDoc.exists()) {
                                const userData = userDoc.data();
                                chatUsers.set(friendId, {
                                    uid: friendId,
                                    name: userData.name,
                                    avatar: userData.avatar,
                                    lastMessage: msg.text,
                                    lastTime: msg.timestamp
                                });
                            }
                        }
                    }
                }

                chats = Array.from(chatUsers.values())
                    .sort((a, b) => (b.lastTime || 0) - (a.lastTime || 0));
                renderChatsList();
            });
        }

        function renderChatsList() {
            if (chats.length === 0) {
                chatsList.innerHTML = '<div style="text-align: center; color: #6c6c70; padding: 20px;">рџ’¬ РќРµС‚ С‡Р°С‚РѕРІ. РќР°Р№РґРёС‚Рµ РґСЂСѓРіР° РїРѕ РїРѕРёСЃРєСѓ!</div>';
                return;
            }

            chatsList.innerHTML = chats.map(chat => `
                        <div class="chat-item ${currentChatUser?.uid === chat.uid ? 'active' : ''}" onclick="window.selectChat('${chat.uid}')">
                            <div class="chat-avatar">
                                ${chat.avatar ? `<img src="${chat.avatar}">` : chat.name.charAt(0).toUpperCase()}
                            </div>
                            <div class="chat-info">
                                <div class="chat-name">${chat.name}</div>
                                <div class="chat-last-message">${chat.lastMessage?.substring(0, 30) || 'РќРµС‚ СЃРѕРѕР±С‰РµРЅРёР№'}</div>
                            </div>
                        </div>
                    `).join('');
        }

        window.selectChat = async (uid) => {
            const userDoc = await getDoc(doc(db, 'users', uid));
            if (userDoc.exists()) {
                currentChatUser = { uid, ...userDoc.data() };
                updateChatHeader();
                loadMessages();
                renderChatsList();
            }
        };

        function updateChatHeader() {
            if (currentChatUser) {
                document.getElementById('chatHeaderName').innerText = currentChatUser.name;
                document.getElementById('chatHeaderStatus').innerHTML = currentChatUser.online ? 'рџџў РІ СЃРµС‚Рё' : 'вљЄ РЅРµ РІ СЃРµС‚Рё';
                const headerAvatar = document.getElementById('chatHeaderAvatar');
                if (currentChatUser.avatar) {
                    headerAvatar.innerHTML = `<img src="${currentChatUser.avatar}">`;
                } else {
                    headerAvatar.innerHTML = currentChatUser.name.charAt(0).toUpperCase();
                }
            } else {
                document.getElementById('chatHeaderName').innerText = 'Р’С‹Р±РµСЂРёС‚Рµ С‡Р°С‚';
                document.getElementById('chatHeaderStatus').innerHTML = '';
            }
        }

        function loadMessages() {
            if (!currentChatUser || !currentUser) return;

            const q = query(collection(db, 'messages'), orderBy('timestamp'));
            onSnapshot(q, (snapshot) => {
                messagesContainer.innerHTML = '';
                let hasMessages = false;

                snapshot.forEach(docSnap => {
                    const msg = docSnap.data();
                    if ((msg.from === currentUser.uid && msg.to === currentChatUser.uid) ||
                        (msg.from === currentChatUser.uid && msg.to === currentUser.uid)) {
                        hasMessages = true;
                        const div = document.createElement('div');
                        div.className = `message ${msg.from === currentUser.uid ? 'outgoing' : 'incoming'}`;
                        div.innerHTML = msg.text;
                        messagesContainer.appendChild(div);
                    }
                });

                if (!hasMessages) {
                    messagesContainer.innerHTML = '<div class="empty-chat">рџ’¬ РќР°РїРёС€РёС‚Рµ РїРµСЂРІРѕРµ СЃРѕРѕР±С‰РµРЅРёРµ!</div>';
                }
                messagesContainer.scrollTop = messagesContainer.scrollHeight;
            });
        }

        async function sendMessage() {
            const input = document.getElementById('messageInput');
            const text = input.value.trim();
            if (!text || !currentChatUser) {
                if (!currentChatUser) alert('РЎРЅР°С‡Р°Р»Р° РІС‹Р±РµСЂРёС‚Рµ С‡Р°С‚!');
                return;
            }

            await addDoc(collection(db, 'messages'), {
                from: currentUser.uid,
                to: currentChatUser.uid,
                text: text,
                timestamp: Date.now()
            });
            input.value = '';
        }

        function openSettings() {
            document.getElementById('modalName').value = currentUser.name;
            document.getElementById('modalPassword').value = '';

            const modalContentDiv = document.getElementById('modalAvatarContent');
            if (currentUser.avatar) {
                modalContentDiv.innerHTML = `<img src="${currentUser.avatar}">`;
            } else {
                modalContentDiv.innerHTML = currentUser.name.charAt(0).toUpperCase();
            }

            settingsModal.classList.remove('hidden');
        }

        async function saveSettings() {
            const newName = document.getElementById('modalName').value.trim();
            const newPassword = document.getElementById('modalPassword').value;

            if (newName && newName !== currentUser.name) {
                await updateDoc(doc(db, 'users', currentUser.uid), { name: newName });
                currentUser.name = newName;
                document.getElementById('myName').innerText = newName;
                updateChatHeader();
                renderChatsList();
            }

            if (newPassword) {
                await updatePassword(auth.currentUser, newPassword);
            }

            settingsModal.classList.add('hidden');
            alert('вњ… РџСЂРѕС„РёР»СЊ РѕР±РЅРѕРІР»С‘РЅ!');
        }

        onAuthStateChanged(auth, async (user) => {
            if (user) {
                const userDoc = await getDoc(doc(db, 'users', user.uid));
                let userData = userDoc.data();

                if (!userData) {
                    userData = { name: user.email.split('@')[0], online: true };
                    await setDoc(doc(db, 'users', user.uid), {
                        uid: user.uid,
                        name: user.email.split('@')[0],
                        email: user.email,
                        online: true,
                        avatar: null
                    });
                } else {
                    await updateDoc(doc(db, 'users', user.uid), { online: true });
                }

                currentUser = { uid: user.uid, ...userData };
                document.getElementById('myName').innerText = currentUser.name;

                loginContainer.classList.add('hidden');
                messengerEl.classList.remove('hidden');

                loadChats();
            } else {
                currentUser = null;
                currentChatUser = null;
                loginContainer.classList.remove('hidden');
                messengerEl.classList.add('hidden');
            }
        });

        document.getElementById('loginBtn').addEventListener('click', () => window.login());
        document.getElementById('registerBtn').addEventListener('click', () => window.register());
        document.getElementById('settingsBtn')?.addEventListener('click', openSettings);
        document.getElementById('saveSettingsBtn')?.addEventListener('click', saveSettings);
        document.getElementById('closeSettingsBtn')?.addEventListener('click', () => {
            settingsModal.classList.add('hidden');
        });
        document.getElementById('logoutFromSettingsBtn')?.addEventListener('click', logout);
        document.getElementById('sendMsgBtn')?.addEventListener('click', sendMessage);
        document.getElementById('messageInput')?.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') sendMessage();
        });

        searchInput.addEventListener('input', (e) => {
            searchUsers(e.target.value);
        });

        document.addEventListener('click', (e) => {
            if (searchResults && !searchResults.contains(e.target) && e.target !== searchInput) {
                searchResults.classList.add('hidden');
            }
        });

        window.addEventListener('beforeunload', async () => {
            if (currentUser) {
                await updateDoc(doc(db, 'users', currentUser.uid), { online: false });
            }
        });
    </script>
</body>
</html>
